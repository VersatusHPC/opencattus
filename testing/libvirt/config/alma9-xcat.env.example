# OpenCATTUS EL9 libvirt/KVM lab configuration for the AlmaLinux 9
# + xCAT validated reference path.
#
# This distro/provisioner pair is part of the validated EL9 test matrix and has
# completed the unattended install, verify, and MPI smoke flow in the lab.
#
# Usage:
#   cp testing/libvirt/config/alma9-xcat.env.example /tmp/opencattus-alma9-xcat.env
#   vi /tmp/opencattus-alma9-xcat.env
#   testing/libvirt/opencattus-el9-lab.sh -c /tmp/opencattus-alma9-xcat.env run

LAB_NAME=opencattus-alma9-xcat

DISTRO_ID=alma
DISTRO_VERSION=9.7
DISTRO_MAJOR=9
PROVISIONER=xcat

# Adjust these asset paths to your local AlmaLinux media.
BASE_IMAGE=/var/lib/libvirt/images/opencattus-assets/AlmaLinux-9-GenericCloud-latest.x86_64.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/opencattus-assets/AlmaLinux-9-latest-x86_64-dvd.iso
OPENCATTUS_MIRROR_URL=http://mirror.local.versatushpc.com.br

# Provide either a prebuilt EL9 binary or the source tree to build inside the headnode.
# OPENCATTUS_BINARY=/absolute/path/to/opencattus
OPENCATTUS_SOURCE_DIR=/absolute/path/to/opencattus

IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

HEADNODE_MEMORY_MB=24576
HEADNODE_VCPUS=8
HEADNODE_DISK_GB=220

COMPUTE_COUNT=1
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2

NODE_SOCKETS=1
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_CPUS_PER_NODE=2
NODE_REAL_MEMORY_MB=4096

REMOTE_BUILD_JOBS=4

MPI_SMOKE_NODES=1
MPI_SMOKE_TASKS=2
