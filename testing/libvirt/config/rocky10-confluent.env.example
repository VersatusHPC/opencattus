# OpenCATTUS EL10 libvirt/KVM lab configuration for the Rocky Linux 10
# Confluent bootstrap path
#
# Copy this file, adjust the paths, and then run:
#   testing/libvirt/opencattus-el10-lab.sh -c /path/to/your.env run

LAB_NAME=opencattus-rocky10-confluent

DISTRO_ID=rocky
DISTRO_VERSION=10.0
DISTRO_MAJOR=10

# Required host-side assets.
BASE_IMAGE=/var/lib/libvirt/images/opencattus-assets/Rocky-10-GenericCloud-Base.latest.x86_64.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/opencattus-assets/Rocky-10-latest-x86_64-dvd.iso

# Provide either a prebuilt EL10 binary or the source tree to build inside the headnode.
# OPENCATTUS_BINARY=/absolute/path/to/opencattus
OPENCATTUS_SOURCE_DIR=/absolute/path/to/opencattus

# Optional override for where the harness stores libvirt-owned qcow2/seed assets.
IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

PROVISIONER=confluent

# VM sizing.
HEADNODE_MEMORY_MB=24576
HEADNODE_VCPUS=8
HEADNODE_DISK_GB=220
COMPUTE_COUNT=1
# For the first multi-node EL10 check later, set:
# COMPUTE_COUNT=2
# MPI_SMOKE_NODES=2
# MPI_SMOKE_TASKS=2
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2
NODE_SOCKETS=1
NODE_CPUS_PER_NODE=2
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_REAL_MEMORY_MB=4096

# Keep guest builds conservative unless you have a much larger headnode VM.
REMOTE_BUILD_JOBS=4

# Cluster identity.
CLUSTER_NAME=opencattus
CLUSTER_HOSTNAME=opencattus
CLUSTER_DOMAIN=cluster.example.com

# Optional time and locale tuning.
TIMEZONE=UTC
TIMESERVER=pool.ntp.org
LOCALE=en_US.utf8
