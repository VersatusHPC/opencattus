# OpenCATTUS EL8 libvirt/KVM lab configuration for the Red Hat Enterprise Linux 8
# + Confluent candidate validation path.
#
# This lane is scaffolded for the EL8 expansion matrix, but it has not completed
# the release-validation flow yet.
#
# Usage:
#   cp testing/libvirt/config/rhel8-confluent.env.example /tmp/opencattus-rhel8-confluent.env
#   vi /tmp/opencattus-rhel8-confluent.env
#   testing/libvirt/opencattus-el8-lab.sh -c /tmp/opencattus-rhel8-confluent.env run

LAB_NAME=opencattus-rhel8-confluent

DISTRO_ID=rhel
DISTRO_VERSION=8.10
DISTRO_MAJOR=8
PROVISIONER=confluent

# Adjust these asset paths to your local entitled RHEL media.
BASE_IMAGE=/var/lib/libvirt/images/opencattus-assets/rhel-8.10-x86_64-kvm.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/opencattus-assets/rhel-8.10-x86_64-dvd.iso
OPENCATTUS_MIRROR_URL=http://mirror.local.versatushpc.com.br

# Provide either a prebuilt EL8 binary or the source tree to build inside the headnode.
# OPENCATTUS_BINARY=/absolute/path/to/opencattus
OPENCATTUS_SOURCE_DIR=/absolute/path/to/opencattus

IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

HEADNODE_MEMORY_MB=24576
HEADNODE_VCPUS=8
HEADNODE_DISK_GB=220

COMPUTE_COUNT=1
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2

NODE_SOCKETS=1
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_CPUS_PER_NODE=2
NODE_REAL_MEMORY_MB=4096

REMOTE_BUILD_JOBS=4

MPI_SMOKE_NODES=1
MPI_SMOKE_TASKS=2

EXTERNAL_GATEWAY_IP=192.168.144.1
EXTERNAL_DHCP_START=192.168.144.100
EXTERNAL_DHCP_END=192.168.144.199
EXTERNAL_HEADNODE_IP=192.168.144.10

MANAGEMENT_GATEWAY_IP=192.168.48.254
MANAGEMENT_HOST_IP=192.168.48.253
