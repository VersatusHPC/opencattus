# OpenCATTUS EL10 libvirt/KVM lab configuration for the Red Hat Enterprise Linux 10
# + Confluent validated reference path.
#
# This distro/provisioner pair is part of the validated EL10 Confluent matrix.
#
# Usage:
#   cp testing/libvirt/config/rhel10-confluent.env.example /tmp/opencattus-rhel10-confluent.env
#   vi /tmp/opencattus-rhel10-confluent.env
#   testing/libvirt/opencattus-el10-lab.sh -c /tmp/opencattus-rhel10-confluent.env run

LAB_NAME=opencattus-rhel10-confluent

DISTRO_ID=rhel
DISTRO_VERSION=10.1
DISTRO_MAJOR=10
PROVISIONER=confluent

# Adjust these asset paths to your local entitled RHEL media.
BASE_IMAGE=/var/lib/libvirt/images/opencattus-assets/rhel-10.1-x86_64-kvm.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/opencattus-assets/rhel-10.1-x86_64-dvd.iso
OPENCATTUS_MIRROR_URL=http://mirror.local.versatushpc.com.br

# Provide either a prebuilt EL10 binary or the source tree to build inside the headnode.
# OPENCATTUS_BINARY=/absolute/path/to/opencattus
OPENCATTUS_SOURCE_DIR=/absolute/path/to/opencattus

IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

HEADNODE_MEMORY_MB=24576
HEADNODE_VCPUS=8
HEADNODE_DISK_GB=220
COMPUTE_COUNT=1
MPI_SMOKE_NODES=1
MPI_SMOKE_TASKS=2
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2
NODE_SOCKETS=1
NODE_CPUS_PER_NODE=2
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_REAL_MEMORY_MB=4096

REMOTE_BUILD_JOBS=4

CLUSTER_NAME=opencattus
CLUSTER_HOSTNAME=opencattus
CLUSTER_DOMAIN=cluster.example.com

TIMEZONE=UTC
TIMESERVER=pool.ntp.org
LOCALE=en_US.utf8
