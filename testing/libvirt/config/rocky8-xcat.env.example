# OpenCATTUS EL8 libvirt/KVM lab configuration for the Rocky Linux 8
# + xCAT validation path.
#
# Usage:
#   cp testing/libvirt/config/rocky8-xcat.env.example /tmp/opencattus-rocky8-xcat.env
#   vi /tmp/opencattus-rocky8-xcat.env
#   testing/libvirt/opencattus-el8-lab.sh -c /tmp/opencattus-rocky8-xcat.env run

LAB_NAME=opencattus-rocky8-xcat

DISTRO_ID=rocky
DISTRO_VERSION=8.10
DISTRO_MAJOR=8
PROVISIONER=xcat

BASE_IMAGE=/var/lib/libvirt/images/opencattus-assets/Rocky-8-GenericCloud-Base.latest.x86_64.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/opencattus-assets/Rocky-8-latest-x86_64-dvd.iso

# Provide either a prebuilt EL8 binary or the source tree to build inside the headnode.
# OPENCATTUS_BINARY=/absolute/path/to/opencattus
OPENCATTUS_SOURCE_DIR=/home/ferrao/opencattus-el8

IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

HEADNODE_MEMORY_MB=24576
HEADNODE_VCPUS=8
HEADNODE_DISK_GB=220

COMPUTE_COUNT=1
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2

NODE_SOCKETS=1
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_CPUS_PER_NODE=2
NODE_REAL_MEMORY_MB=4096

REMOTE_BUILD_JOBS=4

MPI_SMOKE_NODES=1
MPI_SMOKE_TASKS=2

EXTERNAL_GATEWAY_IP=192.168.134.1
EXTERNAL_DHCP_START=192.168.134.100
EXTERNAL_DHCP_END=192.168.134.199
EXTERNAL_HEADNODE_IP=192.168.134.10

MANAGEMENT_GATEWAY_IP=192.168.38.254
MANAGEMENT_HOST_IP=192.168.38.253

# VirtualBMC uses the management subnet for BMC endpoints by default.
# NODE_BMC_IP_BASE_OCTET=101
