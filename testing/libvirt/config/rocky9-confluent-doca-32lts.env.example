# OpenCATTUS EL9 libvirt/KVM lab configuration for the Rocky Linux 9.7
# Confluent application-network + DOCA 3.2 LTS validation path
#
# Copy this file, adjust the paths, and then run:
#   testing/libvirt/opencattus-el9-lab.sh -c /path/to/your.env run

LAB_NAME=opencattus-rocky9-confluent-doca-32lts

DISTRO_ID=rocky
DISTRO_VERSION=9.7
DISTRO_MAJOR=9

# Required host-side assets.
BASE_IMAGE=/var/lib/libvirt/images/opencattus-assets/Rocky-9-GenericCloud-Base-9.7-20251123.2.x86_64.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/opencattus-assets/Rocky-9.7-x86_64-dvd.iso

# Provide either a prebuilt EL9 binary or the source tree to build inside the headnode.
# OPENCATTUS_BINARY=/absolute/path/to/opencattus
OPENCATTUS_SOURCE_DIR=/absolute/path/to/opencattus

# Optional override for where the harness stores libvirt-owned qcow2/seed assets.
IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

PROVISIONER=confluent

# VM sizing.
HEADNODE_MEMORY_MB=24576
HEADNODE_VCPUS=8
HEADNODE_DISK_GB=220
COMPUTE_COUNT=1
MPI_SMOKE_NODES=1
MPI_SMOKE_TASKS=2
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2
NODE_SOCKETS=1
NODE_CPUS_PER_NODE=2
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_REAL_MEMORY_MB=4096

# Keep guest builds conservative unless you have a much larger headnode VM.
REMOTE_BUILD_JOBS=4

# Cluster identity.
CLUSTER_NAME=opencattus
CLUSTER_HOSTNAME=opencattus
CLUSTER_DOMAIN=cluster.example.com

# Optional time and locale tuning.
TIMEZONE=UTC
TIMESERVER=pool.ntp.org
LOCALE=en_US.utf8

# Optional dedicated application network. Override these if another lab is already
# using the default application subnet.
APPLICATION_NETWORK_ENABLED=1
APPLICATION_GATEWAY_IP=172.26.150.254
APPLICATION_NETMASK=255.255.255.0
APPLICATION_PREFIX=24
APPLICATION_DOMAIN=cluster.application.example.com

# DOCA 3.2 LTS validation path for the headnode and compute image.
OFED_ENABLED=1
OFED_KIND=doca
OFED_VERSION=latest-3.2-LTS
