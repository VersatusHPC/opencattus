# OpenCATTUS EL9 libvirt/KVM lab configuration
#
# Copy this file, adjust the paths, and then run:
#   testing/libvirt/opencattus-el9-lab.sh -c /path/to/your.env run

LAB_NAME=opencattus-rocky9

DISTRO_ID=rocky
DISTRO_VERSION=9.6
DISTRO_MAJOR=9

# Required host-side assets.
BASE_IMAGE=/var/lib/libvirt/images/Rocky-9-GenericCloud-Base.latest.x86_64.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/Rocky-9.6-x86_64-dvd.iso
OPENCATTUS_BINARY=/absolute/path/to/opencattus

# Optional override for where the harness stores libvirt-owned qcow2/seed assets.
IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

# The harness is currently focused on the EL9 + xCAT recovery path.
PROVISIONER=xcat

# VM sizing.
HEADNODE_MEMORY_MB=16384
HEADNODE_VCPUS=4
HEADNODE_DISK_GB=220
COMPUTE_COUNT=1
COMPUTE_MEMORY_MB=4096
COMPUTE_VCPUS=2

# Cluster identity.
CLUSTER_NAME=opencattus
CLUSTER_HOSTNAME=opencattus
CLUSTER_DOMAIN=cluster.example.com

# Optional time and locale tuning.
TIMEZONE=UTC
TIMESERVER=pool.ntp.org
LOCALE=en_US.utf8

# Loopback BMC addresses make the xCAT IPMI phase fail fast in the lab.
NODE_BMC_ADDRESS_FORMAT=127.0.0.1
