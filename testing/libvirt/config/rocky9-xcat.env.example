# OpenCATTUS EL9 libvirt/KVM lab configuration
#
# Copy this file, adjust the paths, and then run:
#   testing/libvirt/opencattus-el9-lab.sh -c /path/to/your.env run

LAB_NAME=opencattus-rocky9

DISTRO_ID=rocky
DISTRO_VERSION=9.6
DISTRO_MAJOR=9

# Required host-side assets.
BASE_IMAGE=/var/lib/libvirt/images/Rocky-9-GenericCloud-Base.latest.x86_64.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/Rocky-9.6-x86_64-dvd.iso

# Provide either a prebuilt EL9 binary or the source tree to build inside the headnode.
# OPENCATTUS_BINARY=/absolute/path/to/opencattus
OPENCATTUS_SOURCE_DIR=/absolute/path/to/opencattus

# Optional override for where the harness stores libvirt-owned qcow2/seed assets.
IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

# The harness is currently focused on the EL9 + xCAT recovery path.
PROVISIONER=xcat

# VM sizing.
HEADNODE_MEMORY_MB=16384
HEADNODE_VCPUS=4
HEADNODE_DISK_GB=220
COMPUTE_COUNT=1
# xCAT stateless root images are unpacked in RAM during PXE boot.
# 4 GiB nodes failed consistently during EL9 recovery with initramfs
# "No space left on device" errors while expanding rootimg.cpio.gz.
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2
NODE_SOCKETS=1
NODE_CPUS_PER_NODE=2
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_REAL_MEMORY_MB=4096

# Keep guest builds conservative unless you have a much larger headnode VM.
REMOTE_BUILD_JOBS=4

# Cluster identity.
CLUSTER_NAME=opencattus
CLUSTER_HOSTNAME=opencattus
CLUSTER_DOMAIN=cluster.example.com

# Optional time and locale tuning.
TIMEZONE=UTC
TIMESERVER=pool.ntp.org
LOCALE=en_US.utf8

# VirtualBMC uses the management subnet for BMC endpoints by default.
# MANAGEMENT_HOST_IP=192.168.30.253
# NODE_BMC_IP_BASE_OCTET=101
