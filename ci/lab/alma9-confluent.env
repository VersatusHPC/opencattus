LAB_NAME=jenkins-alma9-confluent-${BUILD_NUMBER:-0}

DISTRO_ID=alma
DISTRO_VERSION=9.7
DISTRO_MAJOR=9
PROVISIONER=confluent

BASE_IMAGE=/var/lib/libvirt/images/AlmaLinux-9-GenericCloud-latest.x86_64.qcow2
CLUSTER_ISO=/var/lib/libvirt/images/AlmaLinux-9-latest-x86_64-dvd.iso
OPENCATTUS_MIRROR_URL=http://mirror.local.versatushpc.com.br

OPENCATTUS_SOURCE_DIR=${WORKSPACE}
IMAGE_ROOT=/var/lib/libvirt/images/opencattus-lab

HEADNODE_MEMORY_MB=24576
HEADNODE_VCPUS=8
HEADNODE_DISK_GB=220

COMPUTE_COUNT=4
COMPUTE_MEMORY_MB=8192
COMPUTE_VCPUS=2

NODE_SOCKETS=1
NODE_CORES_PER_SOCKET=2
NODE_THREADS_PER_CORE=1
NODE_CPUS_PER_NODE=2
NODE_REAL_MEMORY_MB=4096

REMOTE_BUILD_JOBS=4

MPI_SMOKE_NODES=4
MPI_SMOKE_TASKS=4

CLUSTER_NAME=opencattus
CLUSTER_HOSTNAME=opencattus
CLUSTER_DOMAIN=cluster.example.com
TIMEZONE=UTC
TIMESERVER=pool.ntp.org
LOCALE=en_US.utf8

COMPUTE_BOOT_MODES="bios uefi bios uefi"
COMPUTE_PROVISION_TYPES="stateless stateless stateful stateful"
